---
import Anchor from "./Anchor.astro";
import LinkButton from "./LinkButton.astro";
import { slugify } from "@/utils/slugify";

interface FeaturedActivity {
  title: string;
  description: string;
  images: Array<{
    src: string;
    alt: string;
  }>;
}

interface Props {
  title: string;
  shortDescription: string;
  description: string;
  link?: string;
  date: string;
  place?: string;
  image: string;
  featuredActivities: FeaturedActivity[];
}

const {
  title,
  description,
  shortDescription,
  link,
  date,
  place,
  image,
  featuredActivities,
} = Astro.props;
---

<article
  class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0"
>
  <div
    class="relative pb-8 grid before:absolute before:left-[-35px] before:block before:h-full before:border-l-2 before:border-blue-400/30 dark:before:border-blue-500/20 before:content-[''] md:grid-cols-5 md:gap-10 md:space-x-4"
  >
    <div class="relative pb-12 md:col-span-2">
      <div class="sticky top-0">
        <!-- Dot mejorado: sólido azul con punto blanco interior -->
        <span
          class="absolute -left-[46px] top-0.5 flex items-center justify-center w-[22px] h-[22px] rounded-full bg-blue-500 ring-4 ring-white dark:ring-gray-950"
        >
          <span class="w-[7px] h-[7px] rounded-full bg-white"></span>
        </span>

        <!-- Título + badge "Actual" si corresponde -->
        <div class="flex items-start gap-2 pb-2">
          <h3
            class="text-xl font-bold text-blue-600 dark:text-blue-400 leading-snug"
          >
            {title}
          </h3>
          {
            date.toLowerCase().includes("actualidad") && (
              <span class="mt-1 inline-flex shrink-0 items-center px-2 py-0.5 rounded-full text-[11px] font-semibold bg-blue-50 text-blue-700 dark:bg-blue-950 dark:text-blue-300">
                Actual
              </span>
            )
          }
        </div>

        <!-- Empresa con ícono -->
        {
          place && (
            <div class="flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 font-medium mb-1">
              <svg
                class="w-3.5 h-3.5 shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                <polyline points="9,22 9,12 15,12 15,22" />
              </svg>
              {place}
            </div>
          )
        }

        <!-- Fecha con ícono -->
        <div
          class="flex items-center gap-1.5 text-xs text-gray-400 dark:text-gray-500"
        >
          <svg
            class="w-3.5 h-3.5 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          <time>{date}</time>
        </div>
      </div>
    </div>

    <!-- Descripción y botón -->
    <div class="flex-col gap-2 pb-4 md:col-span-3">
      <hr class="border-gray-100 dark:border-white/5 mb-4" />

      <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
        {shortDescription}
      </p>

      <Anchor href={`works-view/${slugify(title + "-" + place)}`}>
        Saber más
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          stroke-width="2.5"
          stroke="currentColor"
          fill="none"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path d="M9 6l6 6l-6 6"></path>
        </svg>
      </Anchor>
    </div>
  </div>
</article>
